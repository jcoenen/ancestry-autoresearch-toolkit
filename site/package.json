{
  "name": "genealogy-toolkit-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "grep -q '\"id\"' src/data/site-data.json 2>/dev/null || cp src/data/fixture-data.json src/data/site-data.json",
    "dev": "vite",
    "build:data": "npx tsx scripts/build-data.ts",
    "build": "npm run build:data && tsc -b && vite build",
    "validate": "npx tsx scripts/validate_vault.ts",
    "export:gedcom": "npx tsx scripts/export-gedcom.ts",
    "import:gedcom": "npx tsx scripts/import-gedcom.ts",
    "next:gedcom-id": "npx tsx scripts/next-gedcom-id.ts",
    "next:source-id": "npx tsx scripts/next-source-id.ts",
    "init": "npx tsx scripts/init-project.ts",
    "upload:media": "npx tsx scripts/upload-media.ts",
    "translations": "npx tsx scripts/manage-translations.ts",
    "audit:obituary-portraits": "npx tsx scripts/audit-obituary-portraits.ts",
    "audit:source-person-links": "npx tsx scripts/audit-source-person-links.ts",
    "backfill:person-media": "npx tsx scripts/backfill-person-media-from-sources.ts",
    "backfill:source-person-ids": "npx tsx scripts/backfill-source-person-ids.ts",
    "backfill:vital-links": "npx tsx scripts/backfill-vital-links.ts",
    "extract:obituary": "npx tsx scripts/extract-obituary.ts",
    "import:obituary-portrait": "npx tsx scripts/import-obituary-portrait.ts",
    "deploy": "npm run build:data && npm run upload:media && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@xyflow/react": "^12.10.1",
    "fuse.js": "^7.1.0",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "leaflet.markercluster": "^1.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@inquirer/prompts": "^8.3.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "gray-matter": "^4.0.3",
    "react-router-dom": "^7.13.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
